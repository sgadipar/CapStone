# ---- Resource Server ----
# Oracle URL — pick the line that matches your setup, copy to .env (no #)
#   Docker Oracle XE  → ORACLE_URL=jdbc:oracle:thin:@//localhost:1521/XEPDB1
#   Standalone Oracle XE (Windows installer) → ORACLE_URL=jdbc:oracle:thin:@//localhost:1522/XEPDB1
ORACLE_URL=jdbc:oracle:thin:@//localhost:1521/XEPDB1
ORACLE_USER=bankapp
ORACLE_PASSWORD=bankapp_password
KAFKA_BOOTSTRAP=localhost:9092
PAYMENT_PROCESSOR_URL=http://localhost:8089
PAYMENT_PROCESSOR_API_KEY=your_api_key
AUTH_SERVER_URL=http://localhost:9000

# ---- BFF ----
OAUTH_CLIENT_SECRET=spa-secret
RESOURCE_SERVER_URL=http://localhost:8082

# ---- BFF (optional: Google "Exceeds" demo) ----
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
