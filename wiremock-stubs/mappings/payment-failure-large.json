{
  "priority": 1,
  "request": {
    "method": "POST",
    "url": "/payments",
    "bodyPatterns": [
      { "matchesJsonPath": "$.[?(@.amount > 10000)]" }
    ]
  },
  "response": {
    "status": 503,
    "headers": { "Content-Type": "application/json" },
    "jsonBody": {
      "status": "REJECTED",
      "reason": "amount exceeds processor limit"
    }
  }
}
